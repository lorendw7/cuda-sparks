{
  "configurations": [
    {
      "name": "Win32",
      // Point IntelliSense at the exact compile commands CMake/Ninja used,
      // so include paths (glad, glfw, our include/) match the real build.
      // Regenerated by build.bat (CMAKE_EXPORT_COMPILE_COMMANDS=ON).
      "compileCommands": "${workspaceFolder}/build/compile_commands.json",
      "cStandard": "c17",
      "cppStandard": "c++17",
      "intelliSenseMode": "windows-msvc-x64"
    }
  ],
  "version": 4
}
